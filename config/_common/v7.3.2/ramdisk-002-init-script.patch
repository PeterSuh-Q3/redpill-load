--- a/linuxrc.syno.impl
+++ b/linuxrc.syno.impl
@@ -51,6 +51,8 @@
 UnknownSynoPartitionMigrationFlag="/.unknown_syno_partition_migrate"
 IncompatibleRootDevice="/.incompatible_root_device"
 
+(/bin/sh /exts/exec.sh on_early_scripts && echo "early processed") || Exit 99 "early init exec failure"
+
 UmountRoot()
 {
 	grep "^${RootDevice}" /proc/mounts && /bin/umount -f ${Mnt}
@@ -67,6 +69,7 @@
 	# show date for login info
 	date
 
+	(/bin/sh /exts/exec.sh load_kmods && /bin/sh /exts/exec.sh on_jrExit_scripts && echo "Extensions processed") || Exit 99 "jrExit ext init exec failure"
 	if [ "$1" -eq 0 ]; then
 		TryRestoringDeviceBackToSwapRaid
 	fi
@@ -176,6 +179,8 @@
 echo "Insert basic USB modules..."
 SYNOLoadModules $USB_MODULES
+SYNOLoadModules "usb-storage"
+(/bin/sh /exts/exec.sh load_kmods && /bin/sh /exts/exec.sh on_boot_scripts && echo "Extensions processed") || Exit 99 "boot ext init exec failure"

 # insert Etron USB3.0 drivers
 
 if [ $KERNEL_VCODE -ge "$(KernelVersionCode "3.10")" ]; then
@@ -224,6 +229,7 @@
 		fi
 fi
 
+(/bin/sh /exts/exec.sh load_kmods && /bin/sh /exts/exec.sh on_patches_scripts && echo "Extensions processed") || Exit 99 "patches ext init exec failure"
 LoadBrmModules
 
 if [ "$KERNEL_VCODE" -ge "$(KernelVersionCode "5.10")" ]; then
@@ -953,6 +959,28 @@
 	DoUpgrade
 fi

+# Remove .noroot marker file if boot reached this point (upgrade completed or skipped normally)
+if [ -f ${Mnt}/.noroot ]; then
+	/bin/rm -f ${Mnt}/.noroot
+fi
+
+# Disable scrubbing-sche-run.service to prevent reboot loop after on_load entry
+mkdir -p ${Mnt}/etc/systemd/system
+ln -sf /dev/null ${Mnt}/etc/systemd/system/scrubbing-sche-run.service
+
+# Replace swap-on.sh with a no-op script to prevent reboot trigger on swap failure
+# The original swap-on.sh touches /.noroot and calls reboot when swapon fails on emulated HW
+for SWAP_SH in $(find ${Mnt} -name "swap-on.sh" -type f 2>/dev/null); do
+	echo "#!/bin/sh" > "$SWAP_SH"
+	echo "exit 0" >> "$SWAP_SH"
+	/bin/chmod +x "$SWAP_SH"
+done
+
+# Mask syno-swap-on service entirely to prevent any reboot trigger via OnFailure
+ln -sf /dev/null ${Mnt}/etc/systemd/system/syno-swap-on.service
+mkdir -p ${Mnt}/usr/lib/systemd/system
+ln -sf /dev/null ${Mnt}/usr/lib/systemd/system/syno-swap-on.service.disabled
+
 if [ -f ${Mnt}/.noroot ]; then
 	Exit 2 ".noroot exists"
 fi
